# Commissioner configuration. Copy to .env and fill in values as needed.
# All variables are optional — see README.md for details.

# Default Sleeper handle used when the client does not supply one.
SLEEPER_USERNAME=

# HTTP port for the Flask server.
PORT=8000

# Set to 1 to enable Flask's reloader and interactive debugger.
# WARNING: never enable in a deployment reachable from the public internet —
# the Werkzeug debugger allows arbitrary code execution.
FLASK_DEBUG=0

# Leave OPENAI_API_KEY unset to run deterministic-only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=25

# Where to persist context snapshots and chat history.
# Defaults to <repo>/data/history.json.
COMMISSIONER_HISTORY_PATH=
